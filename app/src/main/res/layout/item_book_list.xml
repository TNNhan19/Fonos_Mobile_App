<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="190dp"
    android:layout_height="90dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:layout_marginEnd="12dp"
    android:padding="12dp"
    android:background="@drawable/wide_card_bg">

    <TextView
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:gravity="center"
        android:text="🎧"
        android:textSize="26sp"
        android:background="@drawable/chip_inactive" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tóm tắt sách"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tvAuthor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="trong 15 phút"
            android:textColor="#AAB3C5"
            android:textSize="12sp"
            android:maxLines="1" />

        <TextView
            android:id="@+id/tvGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Podcast"
            android:textColor="#38C7FF"
            android:textSize="12sp"
            android:maxLines="1" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnPlay"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:gravity="center"
        android:text="▶"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="@drawable/chip_active" />

    <TextView
        android:id="@+id/btnFavorite"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Favorite" />

    <TextView
        android:id="@+id/btnDownload"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Download" />

    <TextView
        android:id="@+id/btnEdit"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Edit" />

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Delete" />

</LinearLayout>