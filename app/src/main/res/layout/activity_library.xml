<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLibrary"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_galaxy_pure"
    android:fitsSystemWindows="true">

    <!-- ── Scrollable content ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- ── Header ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="36dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:gravity="center"
                android:background="@drawable/chip_active"
                android:text="♪"
                android:textColor="#FFFFFF"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="  Thư viện"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="🔔"
                android:textSize="21sp" />

            <TextView
                android:id="@+id/btnLibraryUser"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:gravity="center"
                android:text="👤"
                android:textSize="21sp"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <!-- ── Search bar ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/input_bg"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="32dp"
                android:layout_height="wrap_content"
                android:text="⌕"
                android:textColor="#AAB3C5"
                android:textSize="25sp"
                android:gravity="center" />

            <EditText
                android:id="@+id/etLibrarySearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Tìm kiếm trong thư viện..."
                android:textColor="#FFFFFF"
                android:textColorHint="#AAB3C5"
                android:textSize="14sp"
                android:background="@null"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:singleLine="true" />

        </LinearLayout>

        <!-- ── Filter chips ── -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <LinearLayout
                android:id="@+id/chipGroupLibrary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />

        </HorizontalScrollView>

        <!-- ── Stats bar: count + sort label + toggle ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="8dp">

            <TextView
                android:id="@+id/tvLibraryCount"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 nội dung"
                android:textColor="#AAB3C5"
                android:textSize="13sp" />

            <!-- Sort label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="★ Rating cao nhất"
                android:textColor="#667EEA"
                android:textSize="12sp"
                android:layout_marginEnd="12dp" />

            <!-- Grid toggle -->
            <Button
                android:id="@+id/btnLibraryGrid"
                android:layout_width="36dp"
                android:layout_height="32dp"
                android:text="▦"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#667EEA"
                android:layout_marginEnd="6dp"
                android:padding="0dp"
                style="@style/Widget.AppCompat.Button.Small" />

            <Button
                android:id="@+id/btnLibraryList"
                android:layout_width="36dp"
                android:layout_height="32dp"
                android:text="☰"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:backgroundTint="#1B2D55"
                android:padding="0dp"
                style="@style/Widget.AppCompat.Button.Small" />

        </LinearLayout>

        <!-- ── Book grid/list RecyclerView ── -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLibrary"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingBottom="8dp"
            android:clipToPadding="false"
            android:scrollbars="none" />

    </LinearLayout>

    <!-- ── Bottom Navigation (4 tabs) ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="74dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/bottom_nav_bg"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="⌂&#10;Trang chủ"
            android:textColor="#AAB3C5"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/navExplore"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="◉&#10;Khám phá"
            android:textColor="#AAB3C5"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▥&#10;Thư viện"
            android:textColor="#1E88FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/navProfile"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:text="♙&#10;Cá nhân"
            android:textColor="#AAB3C5"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

</LinearLayout>
