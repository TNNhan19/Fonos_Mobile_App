<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_margin="8dp">

    <TextView
        android:id="@+id/tvCover"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:gravity="center"
        android:background="@drawable/book_cover_bg"
        android:text="BOOK"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:padding="12dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tên sách"
        android:textColor="#FFFFFF"
        android:textSize="13sp"
        android:textStyle="bold"
        android:maxLines="2"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvAuthor"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tác giả · 2024"
        android:textColor="#AAB3C5"
        android:textSize="12sp"
        android:maxLines="1" />

    <TextView
        android:id="@+id/tvGenre"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Audiobook · Self-help"
        android:textColor="#38C7FF"
        android:textSize="12sp"
        android:maxLines="1" />

    <TextView
        android:id="@+id/tvRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="★ 4.8"
        android:textColor="#38C7FF"
        android:textSize="12sp"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <TextView
            android:id="@+id/btnPlay"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:gravity="center"
            android:text="▶"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/chip_active" />

        <TextView
            android:id="@+id/btnFavorite"
            android:layout_width="0dp"
            android:layout_height="28dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:gravity="center"
            android:text="♡"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:background="@drawable/chip_inactive" />

    </LinearLayout>

    <TextView
        android:id="@+id/btnDownload"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Download" />

    <TextView
        android:id="@+id/btnEdit"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Edit" />

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="gone"
        android:text="Delete" />

</LinearLayout>